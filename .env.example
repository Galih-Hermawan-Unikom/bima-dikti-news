# ============================================
# BIMA DIKTI NEWS - Environment Configuration
# ============================================

# Notifikasi: console, telegram, atau both
NOTIFICATION_METHOD=console

# Kirim file lampiran ke Telegram: true atau false
TELEGRAM_SEND_FILES=false

# Telegram Bot Token (dari @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID (dari @userinfobot)
TELEGRAM_CHAT_ID=

# Interval pengecekan dalam menit
CHECK_INTERVAL_MINUTES=30
